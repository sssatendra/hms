// ─── Prisma Schema ───────────────────────────────────────────────────────────
// HMS - Hospital Management System
// Multi-tenant architecture with tenant_id on every table
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  PHARMACIST
  LAB_TECH
  NURSE
  RECEPTIONIST
  PATIENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
  UNKNOWN
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum AppointmentType {
  CONSULTATION
  FOLLOW_UP
  EMERGENCY
  PROCEDURE
  LAB_VISIT
  RADIOLOGY
  VACCINATION
  TELEMEDICINE
}

enum PrescriptionStatus {
  DRAFT
  ACTIVE
  DISPENSED
  PARTIALLY_DISPENSED
  CANCELLED
  EXPIRED
}

enum LabOrderStatus {
  PENDING
  SAMPLE_COLLECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REJECTED
}

enum LabOrderPriority {
  ROUTINE
  URGENT
  STAT
}

enum PharmacyTransactionType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  EXPIRED_DISPOSAL
  TRANSFER
}

enum InventoryStatus {
  ACTIVE
  LOW_STOCK
  OUT_OF_STOCK
  EXPIRED
  DISCONTINUED
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  PRINT
  APPROVE
  REJECT
}

enum NotificationType {
  APPOINTMENT_REMINDER
  LAB_RESULT_READY
  PRESCRIPTION_READY
  LOW_STOCK_ALERT
  EXPIRY_ALERT
  GENERAL
  SYSTEM
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  RESERVED
}

enum WardType {
  GENERAL
  ICU
  EMERGENCY
  MATERNITY
  PEDIATRIC
  SURGICAL
  CARDIAC
  ONCOLOGY
  PRIVATE
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  INSURANCE
  ONLINE
}

enum AccountType {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
  EQUITY
}

enum InventoryMovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
  SALE
  PURCHASE
  RETURN
}

enum WarehouseType {
  CENTRAL
  PHARMACY
  LAB
  WARD
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  domain      String?
  logo_url    String?
  address     String?
  phone       String?
  email       String?
  timezone    String   @default("UTC")
  is_active   Boolean  @default(true)
  settings    Json     @default("{}")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  users               User[]
  patients            Patient[]
  appointments        Appointment[]
  prescriptions       Prescription[]
  lab_orders          LabOrder[]
  pharmacy_inventories PharmacyInventory[]
  lab_tests           LabTest[]
  wards               Ward[]
  beds                Bed[]
  invoices            Invoice[]
  audit_logs          AuditLog[]
  notifications       Notification[]
  staff_schedules     StaffSchedule[]
  departments         Department[]
  suppliers           Supplier[]
  patient_charges     PatientCharge[]
  progress_notes      ProgressNote[]
  surgery_packages    SurgeryPackage[]
  accounts            Account[]
  warehouses          Warehouse[]
  inventory_items     InventoryItem[]
  journal_entries     JournalEntry[]
  insurance_claims    InsuranceClaim[]

  @@map("tenants")
}

model Department {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  code        String
  description String?
  head_id     String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  head        User?    @relation("DepartmentHead", fields: [head_id], references: [id])
  staff       User[]   @relation("DepartmentStaff")
  wards       Ward[]

  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@map("departments")
}

model Role {
  id          String   @id @default(uuid())
  name        UserRole @unique
  description String?
  permissions Json     @default("[]") // Array of permission strings
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  users       User[]

  @@map("roles")
}

model User {
  id                    String     @id @default(uuid())
  tenant_id             String
  role_id               String
  employee_id           String?
  email                 String
  phone                 String?
  password_hash         String
  first_name            String
  last_name             String
  avatar_url            String?
  status                UserStatus @default(PENDING_VERIFICATION)
  email_verified        Boolean    @default(false)
  phone_verified        Boolean    @default(false)
  two_factor_enabled    Boolean    @default(false)
  two_factor_secret     String?
  last_login_at         DateTime?
  last_login_ip         String?
  password_reset_token  String?
  password_reset_expires DateTime?
  email_verify_token    String?
  refresh_token_hash    String?
  department_id         String?
  specialization        String?    // For doctors
  license_number        String?    // For doctors/pharmacists
  is_active             Boolean    @default(true)
  created_at            DateTime   @default(now())
  updated_at            DateTime   @updatedAt

  // Relations
  tenant              Tenant             @relation(fields: [tenant_id], references: [id])
  role                Role               @relation(fields: [role_id], references: [id])
  department          Department?        @relation("DepartmentStaff", fields: [department_id], references: [id])
  headed_departments  Department[]       @relation("DepartmentHead")
  doctor_appointments Appointment[]      @relation("DoctorAppointments")
  patient_profile     Patient?
  prescriptions       Prescription[]     @relation("DoctorPrescriptions")
  lab_orders_created  LabOrder[]         @relation("LabOrderDoctor")
  lab_orders_processed LabOrder[]        @relation("LabOrderTechnician")
  staff_schedules     StaffSchedule[]
  audit_logs          AuditLog[]
  notifications       Notification[]
  progress_notes      ProgressNote[]

  @@unique([tenant_id, email])
  @@unique([tenant_id, employee_id])
  @@index([tenant_id])
  @@index([tenant_id, role_id])
  @@map("users")
}

model Patient {
  id                  String     @id @default(uuid())
  tenant_id           String
  user_id             String?    @unique // If patient has a login
  mrn                 String     // Medical Record Number
  first_name          String
  last_name           String
  date_of_birth       DateTime
  gender              Gender
  blood_group         BloodGroup @default(UNKNOWN)
  phone               String?
  email               String?
  address             Json?      // { street, city, state, country, zip }
  emergency_contact   Json?      // { name, relation, phone }
  insurance_info      Json?      // { provider, policy_number, group_number, expiry }
  allergies           String[]   @default([])
  chronic_conditions  String[]   @default([])
  is_active           Boolean    @default(true)
  registered_at       DateTime   @default(now())
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  // Relations
  tenant              Tenant           @relation(fields: [tenant_id], references: [id])
  user                User?            @relation(fields: [user_id], references: [id])
  appointments        Appointment[]
  prescriptions       Prescription[]
  lab_orders          LabOrder[]
  bed_admissions      BedAdmission[]
  invoices            Invoice[]
  vital_signs         VitalSign[]
  progress_notes      ProgressNote[]
  charges             PatientCharge[]
  insurance_claims    InsuranceClaim[]

  @@unique([tenant_id, mrn])
  @@index([tenant_id])
  @@index([tenant_id, mrn])
  @@map("patients")
}

model Appointment {
  id              String            @id @default(uuid())
  tenant_id       String
  patient_id      String
  doctor_id       String
  department_id   String?
  type            AppointmentType   @default(CONSULTATION)
  status          AppointmentStatus @default(SCHEDULED)
  scheduled_at    DateTime
  duration_mins   Int               @default(30)
  chief_complaint String?
  notes           String?
  room_number     String?
  follow_up_date  DateTime?
  cancelled_reason String?
  created_by      String?
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  // Relations
  tenant          Tenant            @relation(fields: [tenant_id], references: [id])
  patient         Patient           @relation(fields: [patient_id], references: [id])
  doctor          User              @relation("DoctorAppointments", fields: [doctor_id], references: [id])
  prescriptions   Prescription[]
  lab_orders      LabOrder[]
  vital_signs     VitalSign[]
  invoices        Invoice[]

  @@index([tenant_id])
  @@index([tenant_id, patient_id])
  @@index([tenant_id, doctor_id])
  @@index([tenant_id, scheduled_at])
  @@map("appointments")
}

model VitalSign {
  id              String   @id @default(uuid())
  tenant_id       String
  patient_id      String
  appointment_id  String?
  recorded_by     String?
  temperature     Float?   // Celsius
  blood_pressure_systolic  Int?
  blood_pressure_diastolic Int?
  pulse_rate      Int?
  respiratory_rate Int?
  oxygen_saturation Float?
  height          Float?   // cm
  weight          Float?   // kg
  bmi             Float?
  pain_scale      Int?     // 0-10
  blood_glucose   Float?   // mg/dL
  notes           String?
  recorded_at     DateTime @default(now())
  created_at      DateTime @default(now())

  patient         Patient      @relation(fields: [patient_id], references: [id])
  appointment     Appointment? @relation(fields: [appointment_id], references: [id])
  admission       BedAdmission? @relation(fields: [admission_id], references: [id])
  admission_id    String?

  @@index([tenant_id])
  @@index([tenant_id, patient_id])
  @@index([admission_id])
  @@map("vital_signs")
}

model ProgressNote {
  id              String   @id @default(uuid())
  tenant_id       String
  patient_id      String
  admission_id    String?
  doctor_id       String
  note            String
  category        String   @default("GENERAL") // GENERAL, SOAP, SURGICAL, NURSING
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant          Tenant        @relation(fields: [tenant_id], references: [id])
  patient         Patient       @relation(fields: [patient_id], references: [id])
  admission       BedAdmission? @relation(fields: [admission_id], references: [id])
  doctor          User          @relation(fields: [doctor_id], references: [id])

  @@index([tenant_id])
  @@index([tenant_id, patient_id])
  @@index([admission_id])
  @@map("progress_notes")
}

model PatientCharge {
  id              String   @id @default(uuid())
  tenant_id       String
  patient_id      String
  admission_id    String?
  description     String
  amount          Decimal  @db.Decimal(12, 2)
  quantity        Int      @default(1)
  category        String   @default("OTHER") // SURGERY, RADIOLOGY, LAB, CONSULTATION
  status          String   @default("PENDING") // PENDING, INVOICED
  invoice_id      String?
  is_emergency    Boolean  @default(false)
  payment_status  String   @default("UNPAID") // UNPAID, PAID
  service_status  String   @default("PENDING") // PENDING, APPROVED, COMPLETED
  approved_at     DateTime?
  approved_by     String?
  date            DateTime @default(now())
  performed_by    String?
  created_at      DateTime @default(now())

  tenant          Tenant        @relation(fields: [tenant_id], references: [id])
  patient         Patient       @relation(fields: [patient_id], references: [id])
  admission       BedAdmission? @relation(fields: [admission_id], references: [id])

  @@index([tenant_id])
  @@index([tenant_id, patient_id])
  @@index([admission_id])
  @@map("patient_charges")
}

// ─── Prescription / EMR ───────────────────────────────────────────────────────

model Prescription {
  id              String             @id @default(uuid())
  tenant_id       String
  patient_id      String
  doctor_id       String
  appointment_id  String?
  status          PrescriptionStatus @default(DRAFT)
  diagnosis       String?
  notes           String?
  valid_until     DateTime?
  dispensed_at    DateTime?
  dispensed_by    String?
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt

  // Relations
  tenant          Tenant              @relation(fields: [tenant_id], references: [id])
  patient         Patient             @relation(fields: [patient_id], references: [id])
  doctor          User                @relation("DoctorPrescriptions", fields: [doctor_id], references: [id])
  appointment     Appointment?        @relation(fields: [appointment_id], references: [id])
  items           PrescriptionItem[]
  dispensing_logs DispensingLog[]

  @@index([tenant_id])
  @@index([tenant_id, patient_id])
  @@index([tenant_id, doctor_id])
  @@map("prescriptions")
}

model PrescriptionItem {
  id               String   @id @default(uuid())
  prescription_id  String
  inventory_item_id String?
  drug_name        String
  dosage           String
  dosage_unit      String?  // e.g., mg, ml, tablets
  frequency        String
  duration         String
  days_supply      Int?
  refills          Int      @default(0)
  quantity_prescribed Int
  quantity_dispensed  Int   @default(0)
  route            String?  // oral, IV, topical, etc.
  instructions     String?
  is_substitutable Boolean  @default(false)
  created_at       DateTime @default(now())

  prescription     Prescription      @relation(fields: [prescription_id], references: [id], onDelete: Cascade)
  inventory_item   PharmacyInventory? @relation(fields: [inventory_item_id], references: [id])

  @@index([prescription_id])
  @@map("prescription_items")
}

// ─── Pharmacy ─────────────────────────────────────────────────────────────────

model Supplier {
  id           String   @id @default(uuid())
  tenant_id    String
  name         String
  contact_name String?
  email        String?
  phone        String?
  address      Json?
  license_no   String?
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant       Tenant             @relation(fields: [tenant_id], references: [id])
  inventory    PharmacyInventory[]
  purchase_orders PurchaseOrder[]

  @@index([tenant_id])
  @@map("suppliers")
}

model PharmacyInventory {
  id                String          @id @default(uuid())
  tenant_id         String
  supplier_id       String?
  drug_name         String
  generic_name      String?
  brand_name        String?
  sku               String
  batch_number      String
  barcode           String?
  category          String          // tablet, injection, syrup, etc.
  formulation       String?         // 500mg, 10ml, etc.
  manufacturer      String?
  expiry_date       DateTime
  manufacture_date  DateTime?
  stock_quantity    Int             @default(0)
  reorder_level     Int             @default(10)
  max_stock_level   Int?
  unit_cost         Decimal         @db.Decimal(10, 2)
  selling_price     Decimal         @db.Decimal(10, 2)
  mrp               Decimal?        @db.Decimal(10, 2)
  storage_condition String?         // refrigerated, room temp, etc.
  controlled_drug   Boolean         @default(false)
  status            InventoryStatus @default(ACTIVE)
  location          String?         // shelf location
  is_active         Boolean         @default(true)
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  // Relations
  tenant            Tenant                  @relation(fields: [tenant_id], references: [id])
  supplier          Supplier?               @relation(fields: [supplier_id], references: [id])
  transactions      PharmacyTransaction[]
  prescription_items PrescriptionItem[]
  dispensing_logs   DispensingLog[]
  stock_adjustments StockAdjustment[]

  @@unique([tenant_id, batch_number, sku])
  @@index([tenant_id])
  @@index([tenant_id, sku])
  @@index([tenant_id, expiry_date])
  @@index([tenant_id, status])
  @@map("pharmacy_inventory")
}

model PharmacyTransaction {
  id               String                  @id @default(uuid())
  tenant_id        String
  inventory_item_id String
  type             PharmacyTransactionType
  quantity         Int
  unit_cost        Decimal                 @db.Decimal(10, 2)
  total_amount     Decimal                 @db.Decimal(10, 2)
  reference_id     String?                 // PO number, prescription ID, etc.
  reference_type   String?
  performed_by     String?
  notes            String?
  created_at       DateTime                @default(now())

  inventory_item   PharmacyInventory @relation(fields: [inventory_item_id], references: [id])

  @@index([tenant_id])
  @@index([inventory_item_id])
  @@map("pharmacy_transactions")
}

model DispensingLog {
  id               String   @id @default(uuid())
  tenant_id        String
  prescription_id  String
  inventory_item_id String
  quantity_dispensed Int
  dispensed_by     String
  dispensed_at     DateTime @default(now())
  notes            String?

  prescription     Prescription      @relation(fields: [prescription_id], references: [id])
  inventory_item   PharmacyInventory @relation(fields: [inventory_item_id], references: [id])

  @@index([tenant_id])
  @@index([prescription_id])
  @@map("dispensing_logs")
}

model StockAdjustment {
  id               String   @id @default(uuid())
  tenant_id        String
  inventory_item_id String
  previous_quantity Int
  new_quantity     Int
  adjustment_reason String
  adjusted_by      String
  approved_by      String?
  created_at       DateTime @default(now())

  inventory_item   PharmacyInventory @relation(fields: [inventory_item_id], references: [id])

  @@index([tenant_id])
  @@map("stock_adjustments")
}

model PurchaseOrder {
  id              String   @id @default(uuid())
  tenant_id       String
  supplier_id     String
  po_number       String
  status          String   @default("PENDING") // PENDING, APPROVED, RECEIVED, CANCELLED
  order_date      DateTime @default(now())
  expected_date   DateTime?
  received_date   DateTime?
  total_amount    Decimal  @db.Decimal(12, 2)
  approved_by     String?
  notes           String?
  created_by      String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  supplier        Supplier          @relation(fields: [supplier_id], references: [id])
  items           PurchaseOrderItem[]

  @@unique([tenant_id, po_number])
  @@index([tenant_id])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String   @id @default(uuid())
  purchase_order_id String
  drug_name        String
  quantity_ordered Int
  quantity_received Int     @default(0)
  unit_cost        Decimal  @db.Decimal(10, 2)
  total_cost       Decimal  @db.Decimal(10, 2)
  batch_number     String?
  expiry_date      DateTime?

  purchase_order   PurchaseOrder @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade)

  @@map("purchase_order_items")
}

// ─── Laboratory ───────────────────────────────────────────────────────────────

model LabTest {
  id              String   @id @default(uuid())
  tenant_id       String
  name            String
  code            String
  category        String   // hematology, biochemistry, microbiology, radiology, etc.
  description     String?
  sample_type     String?  // blood, urine, stool, swab, etc.
  sample_volume   String?
  turnaround_time Int?     // hours
  price           Decimal  @db.Decimal(10, 2)
  reference_ranges Json?   // Array of { parameter, min, max, unit, gender, age_group }
  instructions    String?
  is_active       Boolean  @default(true)
  requires_fasting Boolean @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant          Tenant      @relation(fields: [tenant_id], references: [id])
  lab_order_items LabOrderItem[]

  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@map("lab_tests")
}

model LabOrder {
  id              String          @id @default(uuid())
  tenant_id       String
  patient_id      String
  doctor_id       String
  appointment_id  String?
  technician_id   String?
  order_number    String
  status          LabOrderStatus  @default(PENDING)
  priority        LabOrderPriority @default(ROUTINE)
  clinical_notes  String?
  sample_collected_at DateTime?
  sample_id       String?
  completed_at    DateTime?
  rejected_reason String?
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  // Relations
  tenant          Tenant          @relation(fields: [tenant_id], references: [id])
  patient         Patient         @relation(fields: [patient_id], references: [id])
  doctor          User            @relation("LabOrderDoctor", fields: [doctor_id], references: [id])
  appointment     Appointment?    @relation(fields: [appointment_id], references: [id])
  technician      User?           @relation("LabOrderTechnician", fields: [technician_id], references: [id])
  items           LabOrderItem[]
  files           LabFile[]

  @@unique([tenant_id, order_number])
  @@index([tenant_id])
  @@index([tenant_id, patient_id])
  @@index([tenant_id, status])
  @@map("lab_orders")
}

model LabOrderItem {
  id              String   @id @default(uuid())
  lab_order_id    String
  lab_test_id     String
  status          String   @default("PENDING")
  results         Json?    // Array of { parameter, value, unit, reference_min, reference_max, is_abnormal }
  result_notes    String?
  verified_by     String?
  verified_at     DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  lab_order       LabOrder @relation(fields: [lab_order_id], references: [id], onDelete: Cascade)
  lab_test        LabTest  @relation(fields: [lab_test_id], references: [id])

  @@index([lab_order_id])
  @@map("lab_order_items")
}

model LabFile {
  id              String   @id @default(uuid())
  tenant_id       String
  lab_order_id    String
  file_name       String
  original_name   String
  file_type       String   // PDF, DICOM, JPEG, PNG
  mime_type       String
  file_size       Int      // bytes
  minio_bucket    String
  minio_key       String
  checksum        String?
  is_dicom        Boolean  @default(false)
  dicom_metadata  Json?
  uploaded_by     String
  created_at      DateTime @default(now())

  lab_order       LabOrder @relation(fields: [lab_order_id], references: [id])

  @@index([tenant_id])
  @@index([lab_order_id])
  @@map("lab_files")
}

// ─── Ward / Bed Management ────────────────────────────────────────────────────

model Ward {
  id            String   @id @default(uuid())
  tenant_id     String
  department_id String?
  name          String
  code          String
  type          WardType @default(GENERAL)
  daily_rate    Decimal  @db.Decimal(10, 2) @default(0.00)
  total_beds    Int
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant        Tenant      @relation(fields: [tenant_id], references: [id])
  department    Department? @relation(fields: [department_id], references: [id])
  beds          Bed[]

  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@map("wards")
}

model Bed {
  id          String    @id @default(uuid())
  tenant_id   String
  ward_id     String
  bed_number          String
  bed_type            String    @default("Standard")
  daily_rate_override Decimal?  @db.Decimal(10, 2)
  status              BedStatus @default(AVAILABLE)
  is_active           Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  tenant      Tenant         @relation(fields: [tenant_id], references: [id])
  ward        Ward           @relation(fields: [ward_id], references: [id])
  admissions  BedAdmission[]

  @@unique([ward_id, bed_number])
  @@index([tenant_id])
  @@map("beds")
}

model BedAdmission {
  id              String    @id @default(uuid())
  tenant_id       String
  patient_id      String
  bed_id          String
  admitted_at     DateTime  @default(now())
  discharged_at   DateTime?
  admission_notes       String?
  discharge_notes       String?
  diagnosis_on_admission String?
  advance_paid          Decimal   @db.Decimal(12, 2) @default(0.00)
  expected_discharge    DateTime?
  admitted_by           String
  discharged_by   String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  patient         Patient  @relation(fields: [patient_id], references: [id])
  bed             Bed      @relation(fields: [bed_id], references: [id])
  charges         PatientCharge[]
  vitals          VitalSign[]
  progress_notes  ProgressNote[]
  payments        Payment[]

  @@index([tenant_id])
  @@index([patient_id])
  @@map("bed_admissions")
}

// ─── Billing / Invoice ────────────────────────────────────────────────────────

model Invoice {
  id              String        @id @default(uuid())
  tenant_id       String
  patient_id      String
  appointment_id  String?
  invoice_number  String
  status          InvoiceStatus @default(PENDING)
  subtotal        Decimal       @db.Decimal(12, 2)
  discount        Decimal       @db.Decimal(12, 2) @default(0)
  tax             Decimal       @db.Decimal(12, 2) @default(0)
  total           Decimal       @db.Decimal(12, 2)
  paid_amount     Decimal       @db.Decimal(12, 2) @default(0)
  advance_paid    Decimal       @db.Decimal(12, 2) @default(0)
  insurance_amount_covered Decimal @db.Decimal(12, 2) @default(0)
  balance_due     Decimal       @db.Decimal(12, 2) @default(0)
  insurance_provider String?
  insurance_claim_id String?
  due_date        DateTime?
  notes           String?
  created_by      String
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  tenant          Tenant         @relation(fields: [tenant_id], references: [id])
  patient         Patient        @relation(fields: [patient_id], references: [id])
  appointment     Appointment?   @relation(fields: [appointment_id], references: [id])
  insurance_claim InsuranceClaim?
  items           InvoiceItem[]
  payments        Payment[]

  @@unique([tenant_id, invoice_number])
  @@index([tenant_id])
  @@index([tenant_id, patient_id])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoice_id  String
  description String
  quantity    Int     @default(1)
  unit_price  Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  category    String? // consultation, lab, pharmacy, room, procedure

  invoice     Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Payment {
  id             String        @id @default(uuid())
  tenant_id      String
  invoice_id     String?
  amount         Decimal       @db.Decimal(12, 2)
  method         PaymentMethod
  transaction_id String?
  payment_date   DateTime      @default(now())
  notes          String?
  received_by    String

  invoice        Invoice? @relation(fields: [invoice_id], references: [id])
  admission      BedAdmission? @relation(fields: [admission_id], references: [id])
  admission_id   String?

  @@index([tenant_id])
  @@index([invoice_id])
  @@index([admission_id])
  @@map("payments")
}

// ─── Staff Schedule ────────────────────────────────────────────────────────────

model StaffSchedule {
  id          String   @id @default(uuid())
  tenant_id   String
  user_id     String
  day_of_week Int      // 0=Sunday, 6=Saturday
  start_time  String   // "09:00"
  end_time    String   // "17:00"
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  tenant      Tenant @relation(fields: [tenant_id], references: [id])
  user        User   @relation(fields: [user_id], references: [id])

  @@index([tenant_id])
  @@index([user_id])
  @@map("staff_schedules")
}

// ─── System / Audit ──────────────────────────────────────────────────────────

model AuditLog {
  id           String      @id @default(uuid())
  tenant_id    String
  user_id      String?
  action       AuditAction
  resource     String      // table/entity name
  resource_id  String?
  old_values   Json?
  new_values   Json?
  ip_address   String?
  user_agent   String?
  metadata     Json?
  created_at   DateTime    @default(now())

  tenant       Tenant @relation(fields: [tenant_id], references: [id])
  user         User?  @relation(fields: [user_id], references: [id])

  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, resource])
  @@index([created_at])
  @@map("audit_logs")
}

model Notification {
  id          String             @id @default(uuid())
  tenant_id   String
  user_id     String
  type        NotificationType
  status      NotificationStatus @default(PENDING)
  title       String
  message     String
  data        Json?
  read_at     DateTime?
  sent_at     DateTime?
  created_at  DateTime           @default(now())

  tenant      Tenant @relation(fields: [tenant_id], references: [id])
  user        User   @relation(fields: [user_id], references: [id])

  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, status])
  @@map("notifications")
}


// Add to schema.prisma

model SurgeryPackage {
  id              String   @id @default(uuid())
  tenant_id       String
  name            String
  code            String
  description     String?
  base_price      Decimal  @db.Decimal(12, 2)
  inclusions      Json     // Array of included items
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@map("surgery_packages")
}

// ─── Accounting Module ────────────────────────────────────────────────────────

model Account {
  id          String      @id @default(uuid())
  tenant_id   String
  name        String      // e.g., Cash, Pharmacy Sales, Salaries
  code        String      // e.g., 1001, 4001
  type        AccountType
  parent_id   String?
  description String?
  is_active   Boolean     @default(true)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  tenant          Tenant         @relation(fields: [tenant_id], references: [id])
  parent          Account?       @relation("AccountHierarchy", fields: [parent_id], references: [id])
  children        Account[]      @relation("AccountHierarchy")
  ledger_details  LedgerDetail[]

  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@map("accounts")
}

model JournalEntry {
  id              String   @id @default(uuid())
  tenant_id       String
  date            DateTime @default(now())
  reference_type  String?  // INVOICE, PAYMENT, EXPENSE, PURCHASE
  reference_id    String?  // ID of the target object
  notes           String?
  created_by      String
  created_at      DateTime @default(now())

  tenant          Tenant         @relation(fields: [tenant_id], references: [id])
  ledger_details  LedgerDetail[]

  @@index([tenant_id])
  @@index([reference_id, reference_type])
  @@map("journal_entries")
}

model LedgerDetail {
  id               String   @id @default(uuid())
  journal_entry_id String
  account_id       String
  debit            Decimal  @default(0) @db.Decimal(12, 2)
  credit           Decimal  @default(0) @db.Decimal(12, 2)
  created_at       DateTime @default(now())

  journal_entry    JournalEntry @relation(fields: [journal_entry_id], references: [id], onDelete: Cascade)
  account          Account      @relation(fields: [account_id], references: [id])

  @@index([journal_entry_id])
  @@index([account_id])
  @@map("ledger_details")
}

// ─── Unified Inventory ───────────────────────────────────────────────────────

model Warehouse {
  id          String        @id @default(uuid())
  tenant_id   String
  name        String
  code        String
  type        WarehouseType @default(CENTRAL)
  is_active   Boolean       @default(true)
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt

  tenant      Tenant           @relation(fields: [tenant_id], references: [id])
  stocks      InventoryStock[]
  move_from   InventoryMovement[] @relation("MoveFrom")
  move_to     InventoryMovement[] @relation("MoveTo")

  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@map("warehouses")
}

model InventoryItem {
  id              String   @id @default(uuid())
  tenant_id       String
  name            String
  sku             String
  hsn_code        String?
  gst_rate        Decimal  @default(0) @db.Decimal(5, 2)
  category        String   // MEDICINE, CONSUMABLE, EQUIPMENT
  description     String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant          Tenant              @relation(fields: [tenant_id], references: [id])
  stocks          InventoryStock[]
  movements       InventoryMovement[]

  @@unique([tenant_id, sku])
  @@index([tenant_id])
  @@map("inventory_items")
}

model InventoryStock {
  id                String   @id @default(uuid())
  tenant_id         String
  warehouse_id      String
  item_id           String
  batch_number      String
  expiry_date       DateTime
  quantity          Int      @default(0)
  unit_cost         Decimal  @db.Decimal(12, 2)
  selling_price     Decimal  @db.Decimal(12, 2)
  mrp               Decimal? @db.Decimal(12, 2)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  warehouse         Warehouse     @relation(fields: [warehouse_id], references: [id])
  item              InventoryItem @relation(fields: [item_id], references: [id])

  @@unique([warehouse_id, item_id, batch_number])
  @@index([tenant_id])
  @@map("inventory_stocks")
}

model InventoryMovement {
  id               String                @id @default(uuid())
  tenant_id        String
  from_warehouse_id String?
  to_warehouse_id   String?
  item_id          String
  batch_number     String
  quantity         Int
  type             InventoryMovementType
  reference_id     String?               // PO_ID, INVOICE_ID, etc.
  reference_type   String?
  performed_by     String
  created_at       DateTime              @default(now())

  from_warehouse   Warehouse?    @relation("MoveFrom", fields: [from_warehouse_id], references: [id])
  to_warehouse     Warehouse?    @relation("MoveTo", fields: [to_warehouse_id], references: [id])
  item             InventoryItem @relation(fields: [item_id], references: [id])

  @@index([tenant_id])
  @@index([item_id, batch_number])
  @@map("inventory_movements")
}

model InsuranceClaim {
  id              String   @id @default(uuid())
  tenant_id       String
  patient_id      String
  invoice_id      String?  @unique
  provider_name   String
  policy_number   String
  claim_number    String   @unique
  status          String   @default("SUBMITTED") // SUBMITTED, PENDING, APPROVED, REJECTED, SETTLED
  total_amount    Decimal  @db.Decimal(12, 2)
  approved_amount Decimal? @db.Decimal(12, 2)
  settled_at      DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenant_id], references: [id])
  patient         Patient  @relation(fields: [patient_id], references: [id])
  invoice         Invoice? @relation(fields: [invoice_id], references: [id])

  @@index([tenant_id])
  @@index([patient_id])
  @@map("insurance_claims")
}